  },
  "dependencies": {
    "commander": "^13.1.0",
    "docx": "^9.5.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "puppeteer": "^24.4.0"
  },
  "devDependencies": {
    "open": "^10.1.0"
  }
}
