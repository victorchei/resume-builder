{
  "name": "resume-builder",
  "version": "1.0.0",
  "description": "Resume/CV generator — PDF, DOCX, GitHub Pages from single data source",
  "type": "module",
  "bin": {
    "resume": "./src/cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "build:site": "next build",
    "start": "next start",
    "build:cv": "node src/cli.js build",
    "build:all": "node src/cli.js build --all",
    "serve": "node src/cli.js serve",
    "dev:cv": "node src/cli.js serve --open"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "docx": "^9.5.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "next": "^16.1.6",
    "puppeteer": "^24.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "open": "^10.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
